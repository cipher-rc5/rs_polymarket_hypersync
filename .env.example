ENVIO_API_TOKEN=your_envio_api_token_here

# Optional: override default Polygon HyperSync endpoint from indexer spec
ENVIO_HYPERSYNC_URL=https://137.hypersync.xyz

# Optional: set an explicit condition id.
# If omitted, app auto-selects a recent active market.
# CONDITION_ID=0x7b49294de4f325f82b071631ed8222ac5bba5ce95948018aff5a3c2ef6c5e595
AUTO_CONDITION_LOOKBACK_HOURS=24

# Optional: block window (if omitted, app defaults to approximately last 24h)
# FROM_BLOCK=68000000
# TO_BLOCK_EXCL=68020000

# Optional: Polygon RPC endpoint for any future onchain RPC calls
# POLYGON_RPC_URL=https://polygon-rpc.com

# Optional: include Exchange + NegRiskExchange logs. Default is true.
# Backward-compatible alias: INCLUDE_CLOB_LOGS
INCLUDE_EXCHANGE_LOGS=true

# Optional: include OrderFilled logs when exchange logs are enabled. Default is true.
INCLUDE_ORDER_FILLED=true

# Optional: include OrdersMatched logs when exchange logs are enabled. Default is true.
INCLUDE_ORDERS_MATCHED=true

# Optional: include NegRiskAdapter condition logs. Default is true.
INCLUDE_NEG_RISK_LOGS=true

# Optional: stream resilience + progress controls
IO_TIMEOUT_MS=15000
STREAM_RETRY_MAX_ATTEMPTS=6
STREAM_RETRY_BASE_DELAY_MS=500
STREAM_RETRY_MAX_DELAY_MS=10000
PROGRESS_LOG_EVERY_BATCHES=50

# Optional: pre-seed market token IDs when scanning from blocks after TokenRegistered.
# Format: comma-separated hex uint256 ids
# MARKET_TOKEN_IDS=0x1234,0xabcd

# Optional: enable HTTP enrichment from Polymarket endpoints (Gamma + CLOB)
ENABLE_HTTP_ENRICHMENT=true
POLY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLY_CLOB_BASE_URL=https://clob.polymarket.com

# Optional: RTDS websocket enrichment (crypto prices/comments stream)
ENABLE_RTDS_WEBSOCKET=false
POLY_RTDS_URL=wss://ws-live-data.polymarket.com
RTDS_FILTERS=btcusdt,ethusdt,solusdt,xrpusdt
RTDS_PRINT_UPDATES=false
ENABLE_RTDS_STRICT_TLS=true
RTDS_LOG_TLS_DETAILS=true
HTTP_TIMEOUT_MS=4000
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY_MS=150
HTTP_RETRY_MAX_DELAY_MS=2000
RTDS_RETRY_MAX_ATTEMPTS=50
RTDS_RETRY_BASE_DELAY_MS=500
RTDS_RETRY_MAX_DELAY_MS=10000
ENRICHMENT_MAX_IN_FLIGHT=16
# Optional: comma-separated SHA-256 fingerprints of allowed RTDS peer certs.
# If set, connection fails unless peer cert matches one fingerprint.
# RTDS_CERT_SHA256_ALLOWLIST=4d913377e5f3fe05b11a9aec8eb4ad76ed9ef3d7a0be28a79100225592352858

# Optional: persist matched stream rows into DuckDB / Parquet
# All storage outputs are always written under DATA_DIR.
# If EXPORT_* includes a path, only the filename is used.
# DATA_DIR=./data
# EXPORT_DUCKDB_PATH=./polymarket_enriched.duckdb
# EXPORT_PARQUET_PATH=./polymarket_enriched.parquet
STORAGE_BATCH_SIZE=200

# Optional: true to keep tailing new blocks; false runs bounded historical scan.
FOLLOW_TAIL=false
